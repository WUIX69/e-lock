# Copy this file to .env and fill in your real values
# .env is git-ignored and never committed

# ── INFRASTRUCTURE (Docker Compose) ──────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=elock_admin
POSTGRES_PASSWORD=elock_password_2026
POSTGRES_DB=elock_audit_db

# MQTT Broker credentials
MQTT_USERNAME=elock_mqtt
MQTT_PASSWORD=elock_mqtt_2026

# Port overrides (Host side)
DB_PORT=5433
MQTT_PORT=1883
MQTT_WS_PORT=9001
ADMINER_PORT=8080
