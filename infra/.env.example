# Copy this file to infra/.env and fill in your real values
# infra/.env is git-ignored and never committed

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# MQTT Broker credentials
MQTT_USERNAME=
MQTT_PASSWORD=

# Port overrides (optional — defaults shown)
DB_PORT=5432
MQTT_PORT=1883
MQTT_WS_PORT=9001
ADMINER_PORT=8080
