# ── Server-only (never sent to the browser) ────────────────────────────────────
# Database — construct from Root .env values:
# postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@127.0.0.1:<DB_PORT>/<POSTGRES_DB>
DATABASE_URL=postgresql://elock_admin:elock_password_2026@127.0.0.1:5433/elock_audit_db

# MQTT server-side broker connection
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=elock_mqtt
MQTT_PASSWORD=elock_mqtt_2026

# ── Client-side (NEXT_PUBLIC_ prefix — safe to expose) ─────────────────────────
# MQTT WebSocket for browser dashboard
NEXT_PUBLIC_MQTT_WS_URL=ws://localhost:9001
