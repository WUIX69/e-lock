# ── Server-only (never sent to the browser) ────────────────────────────────────
# Database — construct from infra/.env values:
# postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:<DB_PORT>/<POSTGRES_DB>
DATABASE_URL=postgresql://elock_admin:your_password@localhost:5432/elock_audit_db

# MQTT server-side broker connection
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Client-side (NEXT_PUBLIC_ prefix — safe to expose) ─────────────────────────
# MQTT WebSocket for browser dashboard
NEXT_PUBLIC_MQTT_WS_URL=ws://localhost:9001
